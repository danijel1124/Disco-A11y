# Ignore the decompiled source since it's static.
disco/
# DLLs and other build artifacts aren't efficient.
*.dll
*.pdb
mod/bin/
mod/obj/
tools/**/bin/
tools/**/obj/
release/

# Vendored native dependency, not a build artifact - keep despite the *.dll rule above.
!tools/**/TolkNative/*.dll

# Visual Studio solution files
*.sln
disco-all/
tools/DevBridge/UserData/
